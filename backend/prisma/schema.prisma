// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MenuCategory {
  id        String     @id @default(uuid()) @db.Uuid
  nameDe    String
  nameFa    String
  slug      String     @unique
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  items     MenuItem[]
}

model MenuItem {
  id            String       @id @default(uuid()) @db.Uuid
  categoryId    String       @db.Uuid
  category      MenuCategory @relation(fields: [categoryId], references: [id])
  nameDe        String
  nameFa        String
  descriptionDe String
  descriptionFa String?
  price         Decimal      @db.Decimal(10, 2)
  isAvailable   Boolean      @default(true)
  sortOrder     Int          @default(0)
  orderItems    OrderItem[]
}

model Table {
  id           String             @id @default(uuid()) @db.Uuid
  number       Int                @unique
  label        String?
  seats        Int                @default(4)
  status       String             @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED
  reservations TableReservation[]
  orders       Order[]
}

model TableReservation {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  email           String
  phone           String?
  date            DateTime
  time            String
  guests          Int
  tableId         String?  @db.Uuid
  table           Table?   @relation(fields: [tableId], references: [id])
  specialRequests String?
  status          String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt       DateTime @default(now())
}

model EventInquiry {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  email          String
  phone          String
  eventDate      DateTime
  eventTiming    String
  numberOfPeople Int
  eventType      String // ENGAGEMENT, WEDDING, BIRTHDAY, CULTURAL, MUSIC, OTHER
  drinks         String?
  cakes          String?
  food           String?
  equipment      String?
  decor          String?
  otherNotes     String?
  status         String   @default("PENDING") // PENDING, REVIEWED, QUOTED, CONFIRMED, CANCELLED
  createdAt      DateTime @default(now())
}

model EventListing {
  id          String   @id @default(uuid()) @db.Uuid
  titleDe     String
  titleFa     String?
  description String?
  eventDate   DateTime
  eventTime   String
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber Int         @unique @default(autoincrement())
  tableId     String      @db.Uuid
  table       Table       @relation(fields: [tableId], references: [id])
  status      String      @default("NEW") // NEW, PREPARING, READY, SERVED, PAID
  totalAmount Decimal     @default(0.00) @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String   @db.Uuid
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  notes      String?
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String
  role         String   @default("OWNER") // OWNER, MANAGER, WAITER
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Customer {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String?  @unique
  phone      String?  @unique
  points     Int      @default(0)
  totalSpend Decimal  @default(0.00) @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Discount {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  description String?
  type        String    @default("PERCENT") // PERCENT, FIXED
  value       Decimal   @db.Decimal(10, 2)
  minSpend    Decimal?  @db.Decimal(10, 2)
  pointsCost  Int?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}
