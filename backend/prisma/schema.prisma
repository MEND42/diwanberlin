// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MenuCategory {
  id            String         @id @default(uuid()) @db.Uuid
  parentId      String?        @db.Uuid
  parent        MenuCategory?  @relation("CategoryToParent", fields: [parentId], references: [id])
  subcategories MenuCategory[] @relation("CategoryToParent")
  nameDe        String
  nameFa        String
  slug          String         @unique
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  items         MenuItem[]
}

model MenuItem {
  id              String       @id @default(uuid()) @db.Uuid
  categoryId      String       @db.Uuid
  category        MenuCategory @relation(fields: [categoryId], references: [id])
  nameDe          String
  nameFa          String
  nameEn          String?
  descriptionDe   String
  descriptionFa  String?
  descriptionEn  String?
  price           Decimal      @db.Decimal(10, 2)
  imageUrl        String?
  isSpecial       Boolean      @default(false)
  allergens       String?
  isAvailable     Boolean      @default(true)
  sortOrder       Int          @default(0)
  orderItems      OrderItem[]
}

model Table {
  id           String             @id @default(uuid()) @db.Uuid
  number       Int                @unique
  label        String?
  qrToken      String             @unique @default(uuid())
  seats        Int                @default(4)
  status       String             @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED
  reservations TableReservation[]
  orders       Order[]
}

model TableReservation {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  email           String
  phone           String?
  date            DateTime
  time            String
  guests          Int
  tableId         String?  @db.Uuid
  table           Table?   @relation(fields: [tableId], references: [id])
  specialRequests String?
  status          String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt       DateTime @default(now())
}

model EventInquiry {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  email          String
  phone          String
  eventDate      DateTime
  eventTiming    String
  numberOfPeople Int
  eventType      String // ENGAGEMENT, WEDDING, BIRTHDAY, CULTURAL, MUSIC, OTHER
  drinks         String?
  cakes          String?
  food           String?
  equipment      String?
  decor          String?
  otherNotes     String?
  status         String   @default("PENDING") // PENDING, REVIEWED, QUOTED, CONFIRMED, CANCELLED
  createdAt      DateTime @default(now())
}

model EventListing {
  id               String              @id @default(uuid()) @db.Uuid
  titleDe          String
  titleFa          String?
  description      String?
  descriptionFull  String?
  descriptionFa    String?
  imageUrl         String?
  location         String?
  price            Decimal?            @db.Decimal(10, 2)
  maxAttendees     Int?
  registrationOpen Boolean             @default(false)
  eventDate        DateTime
  eventTime        String
  isPublished      Boolean             @default(true)
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  registrations    EventRegistration[]
}

model EventRegistration {
  id             String       @id @default(uuid()) @db.Uuid
  eventListingId String       @db.Uuid
  eventListing   EventListing @relation(fields: [eventListingId], references: [id], onDelete: Cascade)
  name           String
  email          String
  phone          String?
  guests         Int          @default(1)
  message        String?
  status         String       @default("PENDING") // PENDING, CONFIRMED, CANCELLED, WAITLIST
  createdAt      DateTime     @default(now())

  @@index([eventListingId])
}

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber Int         @unique @default(autoincrement())
  tableId     String      @db.Uuid
  table       Table       @relation(fields: [tableId], references: [id])
  status      String      @default("NEW") // NEW, PREPARING, READY, SERVED, PAID
  totalAmount Decimal     @default(0.00) @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String   @db.Uuid
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  notes      String?
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         String   @default("OWNER") // OWNER, MANAGER, WAITER, KITCHEN
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  staffProfile StaffProfile?
  availability StaffAvailability[]
  shifts       ShiftAssignment[]
  timeEntries  TimeEntry[]
  pushSubscriptions PushSubscription[]
  passwordResetTokens PasswordResetToken[]
}

model PushSubscription {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String    @unique
  p256dh    String
  auth      String
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Customer {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String?  @unique
  phone      String?  @unique
  points     Int      @default(0)
  totalSpend Decimal  @default(0.00) @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Discount {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  description String?
  type        String    @default("PERCENT") // PERCENT, FIXED
  value       Decimal   @db.Decimal(10, 2)
  minSpend    Decimal?  @db.Decimal(10, 2)
  pointsCost  Int?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model StaffProfile {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @unique @db.Uuid
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String?
  email       String?
  position    String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StaffAvailability {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @db.Uuid
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  dayOfWeek   Int
  startTime   String
  endTime     String
  note        String?
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ShiftAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @db.Uuid
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  dayOfWeek   Int
  startTime   String
  endTime     String
  note        String?
  status      String    @default("APPROVED") // APPROVED, CANCELLED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TimeEntry {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @db.Uuid
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  clockIn     DateTime
  clockOut    DateTime?
  breakMinutes Int      @default(0)
  note        String?
  status      String    @default("OPEN") // OPEN, SUBMITTED, APPROVED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SiteContentBlock {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  label       String
  type        String   @default("TEXT") // TEXT, TEXTAREA, URL, BOOLEAN
  valueDe     String?
  valueFa     String?
  valueEn     String?
  isPublished Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(uuid()) @db.Uuid
  key             String   @unique
  value           String
  valueDe         String?
  valueFa         String?
  valueEn         String?
  type            String   @default("STRING") // STRING, NUMBER, BOOLEAN
  category        String   @default("general") // general, capacities, contact
  updatedAt       DateTime @updatedAt
}
