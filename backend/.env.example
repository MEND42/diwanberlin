# Cafe Diwan — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — only .env.example is safe to commit.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=

# PostgreSQL (production — populated by Docker Compose)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Diwan Cafe Berlin <hello@diwanberlin.com>
