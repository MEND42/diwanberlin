# Cafe Diwan — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — only .env.example is safe to commit.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for development, PostgreSQL for production
DATABASE_URL=

# PostgreSQL (production — populated by Docker Compose)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Email (Hostinger SMTP) ────────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@diwanberlin.com
SMTP_PASS=
SMTP_FROM=Cafe Diwan <info@diwanberlin.com>
